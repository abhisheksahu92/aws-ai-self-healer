{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "types": ["node", "jest"]
  },
  "include": ["lambdas/**/*", "tasks/**/*", "state-machine/**/*"],
  "exclude": ["node_modules", "dist"]
}
